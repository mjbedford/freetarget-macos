{
  "name": "freetarget-macos",
  "version": "1.0.0",
  "description": "freETarget electronic shooting target desktop app for macOS",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "rebuild": "electron-rebuild -f -w better-sqlite3 serialport",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "postinstall": "electron-rebuild -f -w better-sqlite3 serialport"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@serialport/parser-readline": "^12.0.0",
    "better-sqlite3": "^9.4.3",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.1.4",
    "electron-builder": "^24.9.4",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^2.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  },
  "build": {
    "appId": "com.freetarget.macos",
    "productName": "freETarget",
    "directories": { "output": "release" },
    "mac": {
      "category": "public.app-category.sports",
      "target": "dmg",
      "identity": null
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Sports"
    },
    "deb": {
      "depends": ["libudev1"]
    }
  }
}
